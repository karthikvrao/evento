# Google Cloud Configuration
GOOGLE_GENAI_USE_VERTEXAI=FALSE     # TRUE for Vertex AI, FALSE for AI Studio local dev
GOOGLE_API_KEY=your_api_key_here    # AI Studio API key (local dev only, not needed with Vertex AI)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GCS_BUCKET_NAME=evento-media-xxx
# GOOGLE_APPLICATION_CREDENTIALS=abs/path/to/service-account.json  # ADC via service account

# ADK Configuration
# ADK_LOG_LEVEL=INFO

# Application Configuration
AGENT_APP_NAME=evento

# Firebase settings
FIREBASE_PROJECT_ID=xxx

# Session settings
RUNTIME_ENV=local                   # "local" = InMemorySessionService, "production" = VertexAiSessionService
AGENT_ENGINE_ID=                    # Required when RUNTIME_ENV=production. Create via vertexai.Client().agent_engines.create()
LIVE_API_ENABLED=false
